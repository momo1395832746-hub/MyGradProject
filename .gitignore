# ==========================================
# 毕业设计 Git 忽略清单 
# ==========================================

# 1. 核心大文件与模型权重（绝对不能传！）
models/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.h5
*.onnx

# 2. 实验生成的图片与视频（随时可重新生成，且占空间）
outputs/
*.png
*.jpg
*.jpeg
*.mp4
*.gif

# 3. Python 和 Jupyter 缓存
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# 4. 压缩包与临时文件
*.tar.gz
*.zip
*.log
.locks/

# 5. 虚拟环境（防止不小心把整个环境传上去）
venv/
env/
.env

# 6. 系统自动生成的隐藏文件
.DS_Store
Thumbs.db